# Copy this file to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
VITE_MESHCENTRAL_URL=https://mesh.tudominio.com
# Opcional. Si no se define, la app usa `${VITE_MESHCENTRAL_URL}/meshagents?id=4` (Windows x64)
VITE_MESHCENTRAL_AGENT_DOWNLOAD_URL=
# Opcionales por plataforma (si no se definen, la app usa defaults de MeshCentral)
VITE_MESHCENTRAL_AGENT_WINDOWS_URL=
VITE_MESHCENTRAL_AGENT_MAC_INTEL_URL=
VITE_MESHCENTRAL_AGENT_MAC_ARM_URL=

# ── TURN server (asistencia remota fuera de LAN) ───────────────────────────────
# Usar turns: (TLS) para navegadores en HTTPS. Ejemplo: turns:turn.tudominio.com:5349
VITE_TURN_URL=turns:turn.tudominio.com:5349

# Secret compartido Coturn <-> Edge Function. Genera: openssl rand -hex 32
TURN_SECRET=<genera-con-openssl-rand-hex-32>
TURN_REALM=turn.tudominio.com
TURN_EXTERNAL_IP=<ip-publica-del-vps>

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Cloudflare Zero Trust → Networks → Tunnels → Create tunnel → token
CLOUDFLARE_TUNNEL_TOKEN=<token-del-tunnel>
