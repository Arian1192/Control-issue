# Copy this file to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── RustDesk (frontend integration) ───────────────────────────────────────────
# ID Server = host de hbbs (sin protocolo)
VITE_RUSTDESK_ID_SERVER=rd.tudominio.com
# Relay Server = host:port público de hbbr (opcional, recomendado)
VITE_RUSTDESK_RELAY_SERVER=rd.tudominio.com:21117
# Clave pública de tu servidor RustDesk (contenido de id_ed25519.pub)
VITE_RUSTDESK_KEY=<pega-aqui-id_ed25519.pub>
# URL base del cliente web (si lo exponés)
VITE_RUSTDESK_WEB_CLIENT_URL=https://rd.tudominio.com
# URL opcional con placeholders para abrir el web client pre-rellenado
# Placeholders soportados: {id} y {password}
VITE_RUSTDESK_WEB_CLIENT_TEMPLATE=

# Descargas para usuario final (poné links directos)
VITE_RUSTDESK_DOWNLOAD_WINDOWS_URL=
VITE_RUSTDESK_DOWNLOAD_MAC_INTEL_URL=
VITE_RUSTDESK_DOWNLOAD_MAC_ARM_URL=
VITE_RUSTDESK_DOWNLOAD_LINUX_URL=

# ── RustDesk server (Coolify stack) ───────────────────────────────────────────
# Dominio público de hbbs (para 21115/21116/21118)
RUSTDESK_HBBS_HOST=rd.tudominio.com
# Dominio público + puerto de hbbr (para 21117/21119)
RUSTDESK_RELAY_HOST=rd.tudominio.com:21117
# Y/N (forzar relay siempre). Dejar N salvo necesidad específica.
RUSTDESK_ALWAYS_USE_RELAY=N

# ── Cloudflare Tunnel (solo app web) ─────────────────────────────────────────
# Cloudflare Zero Trust → Networks → Tunnels → Create tunnel → token
CLOUDFLARE_TUNNEL_TOKEN=<token-del-tunnel>
