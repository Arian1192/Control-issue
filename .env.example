# Copy this file to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── TURN server (asistencia remota fuera de LAN) ───────────────────────────────
# El host TURN debe resolver directo al VPS con puertos públicos 3478/5349 y el rango UDP del relay abierto.
# Podés listar varias URLs separadas por coma para mejorar compatibilidad NAT:
#   turn:turn.tudominio.com:3478?transport=udp,turn:turn.tudominio.com:3478?transport=tcp,turns:turn.tudominio.com:5349?transport=tcp
VITE_TURN_URL=turn:turn.tudominio.com:3478?transport=udp,turn:turn.tudominio.com:3478?transport=tcp,turns:turn.tudominio.com:5349?transport=tcp

# Secret compartido Coturn <-> Edge Function. Genera: openssl rand -hex 32
TURN_SECRET=<genera-con-openssl-rand-hex-32>
TURN_REALM=turn.tudominio.com
TURN_EXTERNAL_IP=<ip-publica-del-vps>

# ── Cloudflare Tunnel (opcional, solo para la app web) ───────────────────────
# No sirve para publicar el relay TURN del navegador; TURN debe quedar accesible directo por DNS + puertos públicos.
# Cloudflare Zero Trust → Networks → Tunnels → Create tunnel → token
CLOUDFLARE_TUNNEL_TOKEN=<token-del-tunnel>
